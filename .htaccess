# 301 Redirects for gabrieldalton.com

# Pretty-URL aliases for HTML pages (/headshots → /headshots.html, etc.)
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/]+)/?$ $1.html [L]

# Outbound redirects
Redirect 301 /freewebsite https://freecourse.oasisofchange.org/
Redirect 301 /translink https://gabrieldalton.medium.com/case-study-sustainable-web-practices-for-translink-ca-8e89a49f9f07
Redirect 301 /newsletter https://gabrieldalton.substack.com/
Redirect 301 /vote https://survey.vancouver.ca/s3/awards-of-excellence-2025
Redirect 301 /howtovote https://gabrieldalton.medium.com/how-to-nominate-gabriel-dalton-for-vancouvers-impact-in-innovation-award-e981d2321926
Redirect 301 /tks https://gabrieldalton.medium.com/the-knowledge-society-tks-review-vancouver-irl-6d7fbb42284f
Redirect 301 /yearly https://gabrieldalton.substack.com/t/yearly-updates
Redirect 301 /monthly https://gabrieldalton.substack.com/t/monthly-updates
Redirect 301 /vsb https://www.vsb.bc.ca/city-of-vancouver-honours-digital-sustainability-innovation-led-by-vancouver-student.84832

# Local references / pages
Redirect 301 /recommendations /references.html
Redirect 301 /references /references.html
Redirect 301 /letter-of-recognition-patty-hajdu-pdf /files/Gabriel_Dalton_Letter_of_Recognition_Patty_Hajdu.pdf
Redirect 301 /letter-of-recognition-spencer-chandra-hebert-pdf /files/Gabriel_Dalton_Letter_of_Recognition_Spencer_Chandra_Hebert.pdf
Redirect 301 /letter-of-recommendation-farooq-khan-pdf /files/Gabriel_Dalton_Letter_of_Recommendation_Farooq_Khan.pdf
